# 本機開發用機密範本。
#
# 用法：複製本檔為同目錄下的 secrets.toml 後，把佔位值換成你自己的真實值。
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# secrets.toml 已被 .gitignore 排除、絕不可進版控；雲端部署改用 Community Cloud 的
# Secrets UI 貼上同樣結構。本範本內所有值皆為「虛構佔位值」，僅示意格式，不可直接使用。

# === 允許登入的 email（個資，務必保密）===
# 只有清單內的 Google 帳號登入後可看到財務資料；其餘帳號登入後會被拒絕。
# 可寫成 TOML 陣列（建議）或逗號分隔的單行字串。漏設＝不放行任何人。
# 此 key 必須置於任何 [section] 標頭之前，否則會被 TOML 歸入上一個區塊而非頂層，
# 導致程式讀不到（st.secrets.get("allowed_emails") 回 None）而擋下所有人。
allowed_emails = ["owner@example.com"]

# === Turso 連線（等同資料庫密碼，務必保密）===
[turso]
database_url = "libsql://your-db-name.turso.io"
auth_token = "PASTE_YOUR_TURSO_AUTH_TOKEN_HERE"

# === st.login() 的 Google OIDC 設定 ===
# 需先到 Google Cloud Console 建立 OAuth 2.0 用戶端，並把本機與雲端兩個 redirect_uri
# 都加入授權清單；cookie_secret 為任意高熵隨機字串（自行產生，勿沿用本範本值）。
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "GENERATE_A_RANDOM_HIGH_ENTROPY_STRING"
client_id = "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
